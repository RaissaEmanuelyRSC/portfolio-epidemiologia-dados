# Carregando os pacotes necessários para análise de dados
pacotes <- c(
  "tidyverse", "foreign", "DescTools", "summarytools", "gtsummary", "dygraphs",
  "readr", "readxl", "janitor", "skimr", "stringr", "stringi", "lubridate",
  "writexl", "epitools", "glue"
)

for (p in pacotes) {
  if (!require(p, character.only = TRUE)) {
    install.packages(p)
  }
  library(p, character.only = TRUE)
}
